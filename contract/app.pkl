amends "@app-contract-toolkit/NativeApp.pkl"

import "@app-contract-toolkit/Config.pkl"
import "@app-contract-toolkit/Connectors.pkl"

// ---- App identity ----

name = "metabase"
displayName = "Metabase"
connector = Connectors.METABASE
icon = "https://assets.atlan.com/assets/metabase.svg"
logo = "https://assets.atlan.com/assets/metabase.svg"
credentialConnectorType = "rest"

// ---- Workflow wiring ----
//
// The App class lives in app/connector.py and exposes a single `run()`
// override (openapi pattern). The workflow type matches the app name —
// the SDK registers a single Temporal workflow keyed off this string,
// which the platform's Argo DAG dispatches once for the whole pipeline
// (matches platform-packages/atlan/metabase/templates/default.yaml).
workflowType = "metabase"
hasPublishStep = true

// ---- Lineage pipeline (5-node DAG) ----
//
// extract → qi + publish (parallel) → lineage-app → lineage-publish
//
// The extract phase (this app's @tasks orchestrated by run()) produces
// Atlas JSON for 4 entity types (MetabaseCollection, MetabaseDashboard,
// MetabaseQuestion, BIProcess) at $.extract.outputs.transformed_data_prefix.
//
// The QueryIntelligence node downstream reads SQL strings out of
// ``attributes.metabaseQuery`` on each MetabaseQuestion, scopes parsing
// to the source database via ``attributes.metabaseSourceDatabaseName``
// (and optionally ``metabaseSourceSchemaName``), and emits Process +
// ColumnProcess lineage records. The LineageNode + LineagePublishNode
// then publish those edges to Atlas.
//
// Pattern mirrors atlan-mysql-app/contract/app.pkl.
extraNodes {
  ["qi"] = new QueryIntelligenceNode {
    displayName = "Parse Metabase Question SQL Lineage"
    vendorName = "metabase"
    sqlKey = "attributes.metabaseQuery"
    catalogKey = "attributes.metabaseSourceDatabaseName"
    schemaKey = "attributes.metabaseSourceSchemaName"
    timestampKey = ""
    mineOutputType = "json"
    parsingMode = "competitive"
    inputPrefix = "$.extract.outputs.transformed_data_prefix"
    outputPrefix = "$.extract.outputs.view_lineage_output_prefix"
  }
  ["publish"] = new PublishNode {
    args {
      ["connection_cache_enabled"] = true
      ["connection_cache_via_app_enabled"] = true
      ["current_state_via_app_enabled"] = true
    }
  }
  ["lineage-app"] = new LineageNode {
    connectorName = "metabase"
    sqlUnquotedCase = "lower"
    ignoreAllCase = false
    dependsOn = null
    dependsOnCondition = new DependencyCondition {
      andConditions {
        new DependencyCondition {
          nodeId = "qi"
          tag = "success"
        }
        new DependencyCondition {
          nodeId = "publish"
          tag = "success"
        }
      }
    }
  }
  ["lineage-publish"] = new LineagePublishNode {
    waitForAssetPublish = false
    dependsOn = null
    dependsOnCondition = new DependencyCondition {
      nodeId = "lineage-app"
      tag = "success"
    }
  }
}

// ---- Credential config ----

credentialCommonFields {
  new FieldSpec {
    name = "host"
    displayName = "Host"
    placeholder = "https://<account-id>.metabaseapp.com"
    helpText = "Metabase host URL, including the protocol (e.g. https://my-instance.metabaseapp.com)."
    width = 8
  }
  new FieldSpec {
    name = "port"
    displayName = "Port"
    fieldType = "number"
    defaultValue = "443"
    required = false
    width = 2
  }
}

credentialAuthOptions {
  ["basic"] = new AuthOption {
    label = "Basic"
    fields {
      new FieldSpec {
        name = "username"
        displayName = "Username"
        placeholder = "Metabase username or email"
        width = 4
      }
      new FieldSpec {
        name = "password"
        displayName = "Password"
        placeholder = "Metabase password"
        sensitive = true
        width = 4
      }
    }
  }
}

// ---- Workflow config (UI form) ----

uiConfig {
  tasks {
    ["Credential"] {
      description = "Credential Details"
      inputs {
        ["extraction-method"] = new Config.TextInput {
          title = "Extraction method"
          defaultValue = "direct"
          hide = true
        }
        ["credential-guid"] = new Config.CredentialInput {
          title = ""
          credType = "atlan-connectors-metabase"
          placeholderText = "Credential Guid"
        }
      }
    }
    ["Connection"] {
      description = "Connection Details"
      inputs {
        ["connection"] = new Config.ConnectionCreator {
          title = ""
          placeholderText = "Connection Name"
        }
      }
    }
    ["Metadata"] {
      description = "Metadata"
      inputs {
        ["include-collections"] = new Config.APITree {
          title = "Include collections"
          desc = "Metabase collections to include in the crawl. Empty selection = include all non-personal collections."
          credentialType = "atlan-connectors-metabase"
        }
        ["exclude-collections"] = new Config.APITree {
          title = "Exclude collections"
          desc = "Metabase collections to skip during the crawl."
          credentialType = "atlan-connectors-metabase"
        }
        ["preflight-check"] = new Config.SageV2 {
          title = ""
          checks {
            new Dynamic {
              id = 1
              name = "collectionCountCheck"
              title = "Collection count"
              loaderText = "Counting collections"
            }
            new Dynamic {
              id = 2
              name = "dashboardCountCheck"
              title = "Dashboard count"
              loaderText = "Counting dashboards"
            }
            new Dynamic {
              id = 3
              name = "questionCountCheck"
              title = "Question count"
              loaderText = "Counting questions"
            }
            new Dynamic {
              id = 4
              name = "nativeQueryPermissionCheck"
              title = "Native query permissions"
              loaderText = "Verifying native query permissions"
            }
          }
        }
      }
    }
  }
}
