// Toolkit 0.10.0 consolidated NativeApp.pkl → App.pkl. Widgets are now
// re-exported under `Widgets.*` (no separate Config import needed). App.pkl
// also emits `atlan.yaml` from the typed `deploy { ... }` block, so the
// repo-root atlan.yaml is contract-generated. `app.yaml` is disabled
// (matches hightouch's pattern — it's a toolkit shim with no consumers).
amends "@app-contract-toolkit/App.pkl"

import "@app-contract-toolkit/Connectors.pkl"
import "@app-contract-toolkit/Widgets.pkl"

emitAppYaml = false

// Suppress the auto-generated `entrypoints:` block in atlan.yaml.
//
// We have two @entrypoint methods on MetabaseApp (extract_metadata +
// extract_lineage) but the marketplace treats this as ONE connector card
// (single setup form, single workflow type the user invokes from the UI;
// extract_lineage is invoked downstream by the QI/lineage-publish nodes
// in the DAG, not directly by the user).
//
// Hightouch follows the same shape — 2 @entrypoint methods in code but
// no `entrypoints:` block in atlan.yaml. That's what makes
// local-marketplace register it as single-entrypoint and the frontend
// build URLs WITHOUT `?entrypoint=`, which keeps the-platform in its
// URL-derivation branch (serves `app/generated/<name>.json`) instead of
// the multi-entrypoint branch (which forwards as `<name>-<entrypoint>.json`
// and 404s on us today).
emitEntrypoints = false

// ---- App identity ----

name = "metabase"
displayName = "Metabase Assets"
connector = Connectors.METABASE
icon = "https://assets.atlan.com/assets/metabase.svg"
logo = "https://assets.atlan.com/assets/metabase.svg"
credentialConnectorType = "rest"
appId = "019e3a59-89d2-7310-acea-e8eae494483f"
visibility = "public"
buildTag = "v1"
selfDeployedRuntime = false

// Extra atlan.yaml keys the typed App.pkl doesn't model yet (dockerfile
// path, argo_package_names). Deep-merged on top of the generated atlan.yaml.
atlanYamlOverrides {
  ["dockerfile"] = "./Dockerfile"
  ["argo_package_names"] = new Listing { "@atlan/metabase" }
}

// ---- Deployment config (rendered into atlan.yaml's deploy: block) -----
deploy {
  executionMode = "native"
  replicaCount = 1

  // Toolkit 0.10.4 defaults flipped both of these to true. Pin them
  // off explicitly so the bump is a no-op for deploy behaviour — KEDA
  // scale-to-zero is a separate decision and splitDeployment changes
  // the worker/HTTP container topology.
  splitDeployment = false
  keda {
    enabled = false
  }

  // Dapr sidecars enabled. secretstore is needed for credential
  // resolution (CredentialRef → raw creds via
  // self.context.resolve_credential_raw). objectstore is enabled because
  // the app uploads transformed/ + lineage-stage/ via self.upload(...).
  dapr {
    objectstore = true
    secretstore = true
    statestore = false
    eventstore = false
    subscription = false
    configurationstore = false
    lock = false
  }

  resources = new ResourceConfig {
    requests {
      ["cpu"] = "100m"
      ["memory"] = "256Mi"
    }
    limits {
      ["cpu"] = "500m"
      ["memory"] = "512Mi"
    }
  }

  env {
    ["ATLAN_APP_MODULE"] = "app.connector:MetabaseApp"
    ["ATLAN_HEARTBEAT_TIMEOUT_SECONDS"] = "120"
    ["ATLAN_START_TO_CLOSE_TIMEOUT_SECONDS"] = "86400"
    ["ATLAN_TENANT_ID"] = "default"
    ["APPLICATION_SDK_ENABLE_EVENT_INTERCEPTOR"] = "false"
  }
}

// ---- Workflow wiring ----
//
// Two @entrypoint methods on MetabaseApp (see app/connector.py):
//   - extract_metadata  → workflow "metabase:extract-metadata"
//   - extract_lineage   → workflow "metabase:extract-lineage"
//
// In App.pkl@0.10.0, `workflowTypeOverride` was folded into `workflowType`
// directly. Set it to the explicit per-entrypoint workflow name so the
// first DAG node dispatches the right Temporal workflow.
//
// `hasPublishStep` from NativeApp is folded into `pipeline.publish`
// (default-on in App.pkl@0.10.0).
workflowType = "metabase:extract-metadata"

// ---- Pipeline (5-node DAG, ARS 2.0 publish) ---------------------------
//
//   extract            (this app's `extract_metadata` @entrypoint)
//   ├──► qi            (QueryIntelligenceNode; parses metabaseQuery SQL,
//   │                   reads inputs from transformed_data_prefix,
//   │                   writes parsed-SQL output to view_lineage_output_prefix)
//   ├──► publish       (PublishNode; publishes Collection/Dashboard/Question/
//   │                   BIProcess to Atlan via the publish-app)
//   └──► extract-lineage (this app's `extract_lineage` @entrypoint —
//                         replaces the shared LineageNode because Metabase
//                         is a BI connector and the lineage is cross-connector;
//                         emits ARS 2.0 Process/ColumnProcess records whose
//                         inputs[] carry inline ``arsIdentity`` blocks with
//                         noMatchAction=create_partial, so publish-app's
//                         edge resolver synthesizes PartialObject/PartialField
//                         entities on lookup miss and wires the lineage edge
//                         to them)
//        │
//        └──► lineage-publish (LineagePublishNode; publishes the ARS-staged
//                              Process/ColumnProcess records — no `enable_ars`
//                              flag needed, the node uses ARS 2.0 by default,
//                              and `connection_creation_enabled = false`
//                              keeps it from clobbering the asset connection
//                              cache)
//
// Long timeouts (24h) on every long-running node — the AE default is 2h
// which is too tight for any non-trivial publish on a large tenant
// (matches the canonical `ErrorHandlingConfig` default in the toolkit's
// `PublishStep`).
extraNodes {
  ["qi"] = new QueryIntelligenceNode {
    displayName = "Parse Metabase Question SQL"
    // Metabase questions can target any backend (Snowflake, Redshift,
    // Postgres, H2, BigQuery, …), so SQL dialect must be resolved
    // per-record rather than from a single connector-wide `vendorName`.
    // The connector emits `attributes.metabaseSourceEngine` on each
    // MetabaseQuestion; QI reads that via `vendorKey` to pick the right
    // parser. Without this, QI defaults to its Oracle fallback and every
    // Snowflake/Redshift `LIMIT n` clause fails with a syntax error.
    vendorKey = "attributes.metabaseSourceEngine"
    sqlKey = "attributes.metabaseQuery"
    catalogKey = "attributes.metabaseSourceDatabaseName"
    schemaKey = "attributes.metabaseSourceSchemaName"
    timestampKey = ""
    mineOutputType = "json"
    parsingMode = "competitive"
    inputPrefix = "$.extract.outputs.transformed_data_prefix"
    outputPrefix = "$.extract.outputs.view_lineage_output_prefix"
    errorHandling = new ErrorHandlingConfig {
      startToCloseTimeoutSeconds = 86400
    }
  }
  ["publish"] = new PublishNode {
    errorHandling = new ErrorHandlingConfig {
      startToCloseTimeoutSeconds = 86400
    }
    args {
      ["connection_cache_enabled"] = true
      ["connection_cache_via_app_enabled"] = true
      ["current_state_via_app_enabled"] = true
    }
  }
  ["extract-lineage"] = new DAGNode {
    displayName = "Build Metabase Cross-Connector Lineage"
    workflowType = "metabase:extract-lineage"
    appName = "{app_name}"
    taskQueue = "atlan-metabase-{deployment_name}"
    errorHandling = new ErrorHandlingConfig {
      startToCloseTimeoutSeconds = 86400
    }
    args {
      ["workflow_id"] = "{{workflow-id}}"
      ["connection"] = "{{connection}}"
      ["connection_qualified_name"] = "$.extract.outputs.connection_qualified_name"
      ["view_lineage_input_prefix"] = "$.extract.outputs.view_lineage_output_prefix"
    }
    dependsOn = null
    dependsOnCondition = new DependencyCondition {
      andConditions {
        new DependencyCondition {
          nodeId = "qi"
          tag = "success"
        }
        new DependencyCondition {
          nodeId = "publish"
          tag = "success"
        }
      }
    }
  }
  ["lineage-publish"] = new LineagePublishNode {
    // ARS 2.0 publish — PublishNode-class read of Process/ColumnProcess
    // emitted by extract-lineage, resolved via publish-app's modern ARS
    // resolver (the shared `lineage-app` is intentionally skipped).
    upstream = "extract-lineage"
    transformedDataPrefix = "$.extract-lineage.outputs.lineage_stage_prefix"
    publishStatePrefix = "$.extract-lineage.outputs.lineage_publish_state_prefix"
    currentStatePrefix = "$.extract-lineage.outputs.lineage_current_state_prefix"
    waitForAssetPublish = false

    // Pin lineage-publish's cache flags to `false`. The connection-cache
    // index (SQLite, mapping typeName + qualifiedName → metadata) is built
    // and uploaded by the asset publish step from Database/Schema/Table-class
    // rows. If lineage-publish also writes the index from lineage-stage data
    // (Process / ColumnProcess), it overwrites the asset crawler's index and
    // breaks downstream qualified-name lookups for miners / BI lineage builders.
    //
    // Toolkit 0.10.0 (what this app pins) defaults these to `true` for
    // LineagePublishNode — fixed upstream in INTERNAL-TICKET to
    // `false`, but not yet released. Remove these two overrides once we
    // bump to toolkit > 0.10.0.
    connectionCacheEnabled = false
    connectionCacheViaAppEnabled = false

    errorHandling = new ErrorHandlingConfig {
      startToCloseTimeoutSeconds = 86400
    }
    dependsOn = null
    dependsOnCondition = new DependencyCondition {
      nodeId = "extract-lineage"
      tag = "success"
    }
  }
}

// ---- Credential config ----

credentialCommonFields {
  new FieldSpec {
    name = "host"
    displayName = "Host"
    placeholder = "https://<account-id>.metabaseapp.com"
    helpText = "Metabase host URL, including the protocol (e.g. https://my-instance.metabaseapp.com)."
    width = 8
  }
  new FieldSpec {
    name = "port"
    displayName = "Port"
    fieldType = "number"
    defaultValue = "443"
    required = false
    width = 2
  }
}

credentialAuthOptions {
  ["basic"] = new AuthOption {
    label = "Basic"
    fields {
      new FieldSpec {
        name = "username"
        displayName = "Username"
        placeholder = "Metabase username or email"
        width = 4
      }
      new FieldSpec {
        name = "password"
        displayName = "Password"
        placeholder = "Metabase password"
        sensitive = true
        width = 4
      }
    }
  }
}

// ---- Agent (SDR) credential config -----------------------------------
//
// Drives the SDR credential collection path so the same connector can run
// either via the Atlan tenant's direct credential store (``extraction-method
// = direct``) OR via a self-deployed agent that fetches creds from the
// customer's own secret store (``extraction-method = agent``).
//
// Mirrors atlan-mysql-app's pattern but stripped to basic-auth only —
// Metabase's REST API has no IAM / role-arn auth surface, so the iam_user /
// iam_role blocks mysql carries don't apply. The ``Store Credential Path``
// placeholders signal to the agent UI that the operator should paste a vault
// path (not a literal credential) into each field; the agent later resolves
// each path against its own secret store at extract time.
//
// Without this block (and the AgentSelector widget below), the toolkit
// doesn't emit ``agent_json`` into the generated manifest's extract args,
// so AGENT-mode workflows arrive at the worker with ``input.agent_json ==
// None`` and ``CredentialRef.resolve(input)`` falls all the way through to
// ``_build_client: no credential_ref or inline_credentials``.

local agentConfig: Listing = new {
  new Listing {
    "atlan-connectors-metabase"
    new Mapping {
      ["properties"] = new Mapping {
        ["auth-type"] = new Mapping {
          ["enum"] = new Listing { "basic" }
          ["enumNames"] = new Listing { "Basic" }
        }
        ["basic"] = new Mapping {
          ["properties"] = new Mapping {
            ["username"] = new Mapping {
              ["default"] = ""
              ["ui"] = new Mapping { ["placeholder"] = "Store Credential Path" }
            }
            ["password"] = new Mapping {
              ["default"] = ""
              ["ui"] = new Mapping {
                ["widget"] = ""
                ["placeholder"] = "Store Credential Path"
              }
            }
          }
        }
      }
    }
  }
  new Listing { "atlan-connectors-agent" }
}

// ---- Workflow config (UI form) ----

uiConfig {
  tasks {
    ["Credential"] {
      description = "Credential Details"
      inputs {
        // Conditional radio gated behind the ``SECURE_AGENT_EXTRACTION``
        // lab flag — defaults to a single "direct" option so the
        // production UI is unchanged unless the tenant opts into the
        // agent path. When the flag is on, ``overrideEnum`` exposes the
        // "agent" option alongside "direct" and ``AgentSelector`` below
        // becomes the right-hand widget. Matches the shape mysql ships.
        ["extraction-method"] = new Widgets.ConditionalInput {
          title = "Extraction method"
          helpText = "Determines how the package extracts metadata. 'Direct' connects to Metabase from Atlan's tenant. 'Self-Deployed Runtime' fetches metadata via the Atlan secure agent installed by the customer."
          placeholderText = "Direct"
          baseWidgetType = "radio"
          baseEnum { "direct" }
          baseEnumNames { "Direct" }
          default = "direct"
          required = true
          conditions {
            new Widgets.Condition {
              property = "labFlag"
              value = "SECURE_AGENT_EXTRACTION"
              overrideEnum { "direct"; "agent" }
              overrideEnumNames { "Direct"; "Self-Deployed Runtime" }
            }
          }
          validationRules {
            new Widgets.ValidationRule {
              required = true
              message = "Please select a valid metadata extraction strategy"
            }
          }
        }
        ["credential-guid"] = new Widgets.CredentialInput {
          title = ""
          credType = "atlan-connectors-metabase"
        }
        // The agent-mode counterpart of ``credential-guid``. When
        // ``extraction-method = agent`` the UIRule at the bottom of this
        // block requires ``agent-json`` instead of ``credential-guid``;
        // the toolkit emits ``"agent_json": "{{agent-json}}"`` into
        // ``app/generated/manifest.json``'s ``dag.extract.inputs.args``
        // as long as this widget is declared.
        ["agent-json"] = new Widgets.AgentSelector {
          title = ""
          placeholderText = "Agent JSON"
          agentConfigEntries = agentConfig
        }
      }
    }
    ["Connection"] {
      description = "Connection Details"
      inputs {
        ["connection"] = new Widgets.ConnectionCreator {
          title = ""
        }
      }
    }
    ["Metadata"] {
      description = "Metadata"
      inputs {
        ["include-collections"] = new Widgets.APITree {
          title = "Include collections"
          desc = "Metabase collections to include in the crawl. Empty selection = include all non-personal collections."
          credentialType = "atlan-connectors-metabase"
        }
        ["exclude-collections"] = new Widgets.APITree {
          title = "Exclude collections"
          desc = "Metabase collections to skip during the crawl."
          credentialType = "atlan-connectors-metabase"
        }
        ["preflight-check"] = new Widgets.SageV2 {
          title = ""
          checks {
            new Dynamic {
              id = 1
              name = "collectionCountCheck"
              title = "Collection count"
              loaderText = "Counting collections"
            }
            new Dynamic {
              id = 2
              name = "dashboardCountCheck"
              title = "Dashboard count"
              loaderText = "Counting dashboards"
            }
            new Dynamic {
              id = 3
              name = "questionCountCheck"
              title = "Question count"
              loaderText = "Counting questions"
            }
            new Dynamic {
              id = 4
              name = "nativeQueryPermissionCheck"
              title = "Native query permissions"
              loaderText = "Verifying native query permissions"
            }
          }
        }
      }
    }
  }
  // Required-field routing across extraction modes. Direct mode needs the
  // credential-guid (the Atlan tenant resolves it from its secret store);
  // agent mode needs the AgentSelector payload (the customer-side agent
  // resolves each Store Credential Path against its own secret store).
  // Mirrors atlan-mysql-app's UIRule pair.
  rules {
    new Widgets.UIRule {
      whenInputs { ["extraction-method"] = "direct" }
      required { "credential-guid"; "include-collections"; "preflight-check" }
    }
    new Widgets.UIRule {
      whenInputs { ["extraction-method"] = "agent" }
      required { "agent-json"; "include-collections" }
    }
  }
}
