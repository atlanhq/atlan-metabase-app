{
  "id": "atlan-metabase",
  "name": "Metabase",
  "logo": "https://assets.atlan.com/assets/metabase.svg",
  "config": {
    "properties": {
      "connection": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "connection",
          "label": "",
          "placeholder": "Connection Name"
        }
      },
      "credential-guid": {
        "type": "string",
        "required": true,
        "ui": {
          "widget": "credential",
          "label": "",
          "credentialType": "atlan-connectors-metabase",
          "placeholder": "Credential Guid",
          "hidden": false
        }
      },
      "include-collections": {
        "type": "object",
        "additionalProperties": {
          "type": "array"
        },
        "default": "{}",
        "ui": {
          "widget": "apitree",
          "connectorConfigName": "atlan-connectors-metabase",
          "credential": "credential-guid",
          "label": "Include Collections",
          "description": "Questions and Dashboards from the selected collections will be fetched. Exclude gets preference over include.",
          "grid": 4
        }
      },
      "exclude-collections": {
        "type": "object",
        "additionalProperties": {
          "type": "array"
        },
        "default": "{}",
        "ui": {
          "widget": "apitree",
          "connectorConfigName": "atlan-connectors-metabase",
          "credential": "credential-guid",
          "label": "Exclude Collections",
          "description": "Questions and Dashboards from the selected collections will not be fetched.",
          "grid": 4
        }
      },
      "preflight-check": {
        "type": "string",
        "ui": {
          "widget": "sage",
          "config": [
            {
              "id": 1,
              "name": "collectionCountCheck",
              "extraUrlParam": "",
              "optional": false,
              "title": "Collection Count",
              "loaderText": "Fetching collection count..."
            },
            {
              "id": 2,
              "name": "dashboardCountCheck",
              "extraUrlParam": "",
              "optional": false,
              "title": "Dashboard Count",
              "loaderText": "Fetching dashboard count..."
            },
            {
              "id": 3,
              "name": "questionCountCheck",
              "extraUrlParam": "",
              "optional": false,
              "title": "Question Count",
              "loaderText": "Fetching question count..."
            },
            {
              "id": 4,
              "name": "nativeQueryPermissionCheck",
              "extraUrlParam": "",
              "optional": false,
              "title": "Native Query Editing Permission",
              "loaderText": "Checking if Native Query Editing enabled on allowed databases..."
            }
          ]
        }
      }
    },
    "steps": [
      {
        "id": "credential",
        "title": "Credential",
        "description": "Credential Details",
        "properties": ["credential-guid"]
      },
      {
        "id": "connection",
        "title": "Connection",
        "description": "Connection Details",
        "properties": ["connection"]
      },
      {
        "id": "metadata",
        "title": "Metadata",
        "description": "Metadata",
        "properties": ["include-collections", "exclude-collections", "preflight-check"]
      }
    ]
  }
}
