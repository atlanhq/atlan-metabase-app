{
  "execution_mode": "automation-engine",
  "dag": {
    "extract": {
      "activity_name": "execute_workflow",
      "activity_display_name": "Extract Metabase Metadata",
      "app_name": "{app_name}",
      "inputs": {
        "workflow_type": "metabase",
        "app_name": "{app_name}",
        "app_id": "",
        "argo_workflow_slug": "",
        "task_queue": "atlan-metabase-{deployment_name}",
        "args": {
          "credential": "{{credential}}",
          "credential_guid": "{{credential-guid}}",
          "connection": "{{connection}}",
          "extraction_method": "{{extraction-method}}",
          "include_collections": "{{include-collections}}",
          "exclude_collections": "{{exclude-collections}}",
          "preflight_check": "{{preflight-check}}"
        }
      }
    },
    "qi": {
      "activity_name": "execute_workflow",
      "activity_display_name": "Parse Metabase Question SQL Lineage",
      "app_name": "automation-engine",
      "inputs": {
        "workflow_type": "QueryIntelligenceWorkflow",
        "app_name": "automation-engine",
        "task_queue": "atlan-query-intelligence-{deployment_name}",
        "args": {
          "connection_qualified_name": "$.extract.outputs.connection_qualified_name",
          "input_prefix": "$.extract.outputs.transformed_data_prefix",
          "output_prefix": "$.extract.outputs.view_lineage_output_prefix",
          "sql_key": "attributes.metabaseQuery",
          "catalog_key": "attributes.metabaseSourceDatabaseName",
          "schema_key": "attributes.metabaseSourceSchemaName",
          "timestamp_key": "",
          "mine_output_type": "json",
          "parsing_mode": "competitive",
          "vendor_name": "metabase"
        }
      },
      "depends_on": {
        "node_id": "extract"
      }
    },
    "publish": {
      "activity_name": "execute_workflow",
      "activity_display_name": "Publish to Atlas",
      "app_name": "publish",
      "inputs": {
        "workflow_type": "PublishWorkflow",
        "app_name": "publish",
        "task_queue": "atlan-publish-{deployment_name}",
        "args": {
          "connection_qualified_name": "$.extract.outputs.connection_qualified_name",
          "transformed_data_prefix": "$.extract.outputs.transformed_data_prefix",
          "publish_state_prefix": "$.extract.outputs.publish_state_prefix",
          "current_state_prefix": "$.extract.outputs.current_state_prefix",
          "connection_creation_enabled": true,
          "executor_enabled": true,
          "connection_entity": "{{connection}}",
          "connection_cache_enabled": true,
          "connection_cache_via_app_enabled": true,
          "current_state_via_app_enabled": true
        }
      },
      "depends_on": {
        "node_id": "extract"
      }
    },
    "extract-lineage": {
      "activity_name": "execute_workflow",
      "activity_display_name": "Build Metabase Cross-Connector Lineage",
      "app_name": "{app_name}",
      "inputs": {
        "workflow_type": "metabase:extract-lineage",
        "app_name": "{app_name}",
        "task_queue": "atlan-metabase-{deployment_name}",
        "args": {
          "workflow_id": "{{workflow-id}}",
          "connection": "{{connection}}",
          "connection_qualified_name": "$.extract.outputs.connection_qualified_name",
          "view_lineage_input_prefix": "$.extract.outputs.view_lineage_output_prefix"
        }
      },
      "depends_on": {
        "and_conditions": [
          {
            "node_id": "qi",
            "tag": "success"
          },
          {
            "node_id": "publish",
            "tag": "success"
          }
        ]
      }
    },
    "lineage-publish": {
      "activity_name": "execute_workflow",
      "activity_display_name": "Publish Lineage to Atlas",
      "app_name": "publish",
      "inputs": {
        "workflow_type": "PublishWorkflow",
        "app_name": "publish",
        "task_queue": "atlan-publish-{deployment_name}",
        "args": {
          "connection_qualified_name": "$.extract.outputs.connection_qualified_name",
          "transformed_data_prefix": "$.extract-lineage.outputs.lineage_stage_prefix",
          "publish_state_prefix": "$.extract-lineage.outputs.lineage_publish_state_prefix",
          "current_state_prefix": "$.extract-lineage.outputs.lineage_current_state_prefix",
          "connection_creation_enabled": false,
          "executor_enabled": true,
          "cache_namespace": "lineage",
          "connection_entity": "{{connection}}",
          "connection_cache_enabled": true,
          "connection_cache_via_app_enabled": true,
          "current_state_via_app_enabled": true
        }
      },
      "depends_on": {
        "node_id": "extract-lineage",
        "tag": "success"
      }
    }
  }
}
