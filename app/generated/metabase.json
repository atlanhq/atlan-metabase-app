{
  "id": "metabase",
  "name": "Metabase Assets",
  "logo": "https://assets.atlan.com/assets/metabase.svg",
  "config": {
    "properties": {
      "extraction-method": {
        "type": "conditional",
        "required": true,
        "ui": {
          "widget": "radio",
          "label": "Extraction method",
          "hidden": false,
          "help": "Determines how the package extracts metadata. 'Direct' connects to Metabase from Atlan's tenant. 'Self-Deployed Runtime' fetches metadata via the Atlan secure agent installed by the customer.",
          "placeholder": "Direct",
          "grid": 8,
          "rules": [
            {
              "required": true,
              "message": "Please select a valid metadata extraction strategy"
            }
          ]
        },
        "default": "direct",
        "conditions": [
          {
            "property": "labFlag",
            "value": "SECURE_AGENT_EXTRACTION",
            "enum": [
              "direct",
              "agent"
            ],
            "enumNames": [
              "Direct",
              "Self-Deployed Runtime"
            ]
          }
        ],
        "enum": [
          "direct"
        ],
        "enumNames": [
          "Direct"
        ]
      },
      "credential-guid": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "credential",
          "label": "",
          "hidden": false,
          "help": "",
          "grid": 8,
          "credentialType": "atlan-connectors-metabase",
          "isTestAuthenticationDisabled": false
        }
      },
      "agent-json": {
        "type": "object",
        "required": false,
        "ui": {
          "widget": "agent",
          "label": "",
          "hidden": false,
          "help": "",
          "placeholder": "Agent JSON",
          "grid": 8,
          "agentConfigs": [
            [
              "atlan-connectors-metabase",
              {
                "properties": {
                  "auth-type": {
                    "enum": [
                      "basic"
                    ],
                    "enumNames": [
                      "Basic"
                    ]
                  },
                  "basic": {
                    "properties": {
                      "username": {
                        "default": "",
                        "ui": {
                          "placeholder": "Store Credential Path"
                        }
                      },
                      "password": {
                        "default": "",
                        "ui": {
                          "widget": "",
                          "placeholder": "Store Credential Path"
                        }
                      }
                    }
                  }
                }
              }
            ],
            [
              "atlan-connectors-agent"
            ]
          ]
        }
      },
      "connection": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "connection",
          "label": "",
          "hidden": false,
          "help": "",
          "grid": 8
        }
      },
      "include-collections": {
        "type": "object",
        "required": false,
        "ui": {
          "widget": "apitree",
          "label": "Include collections",
          "hidden": false,
          "help": "",
          "grid": 8,
          "connectorConfigName": "atlan-connectors-metabase",
          "credential": "credential-guid",
          "description": "Metabase collections to include in the crawl. Empty selection = include all non-personal collections."
        },
        "additionalProperties": {
          "type": "array"
        },
        "default": {}
      },
      "exclude-collections": {
        "type": "object",
        "required": false,
        "ui": {
          "widget": "apitree",
          "label": "Exclude collections",
          "hidden": false,
          "help": "",
          "grid": 8,
          "connectorConfigName": "atlan-connectors-metabase",
          "credential": "credential-guid",
          "description": "Metabase collections to skip during the crawl."
        },
        "additionalProperties": {
          "type": "array"
        },
        "default": {}
      },
      "preflight-check": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "sageV2",
          "label": "",
          "hidden": false,
          "help": "",
          "grid": 8,
          "config": [
            {
              "id": 1,
              "name": "collectionCountCheck",
              "title": "Collection count",
              "loaderText": "Counting collections"
            },
            {
              "id": 2,
              "name": "dashboardCountCheck",
              "title": "Dashboard count",
              "loaderText": "Counting dashboards"
            },
            {
              "id": 3,
              "name": "questionCountCheck",
              "title": "Question count",
              "loaderText": "Counting questions"
            },
            {
              "id": 4,
              "name": "nativeQueryPermissionCheck",
              "title": "Native query permissions",
              "loaderText": "Verifying native query permissions"
            }
          ]
        }
      }
    },
    "anyOf": [
      {
        "properties": {
          "extraction-method": {
            "const": "direct"
          }
        },
        "required": [
          "credential-guid",
          "include-collections",
          "preflight-check"
        ]
      },
      {
        "properties": {
          "extraction-method": {
            "const": "agent"
          }
        },
        "required": [
          "agent-json",
          "include-collections"
        ]
      }
    ],
    "steps": [
      {
        "title": "Credential",
        "description": "Credential Details",
        "id": "credential",
        "properties": [
          "extraction-method",
          "credential-guid",
          "agent-json"
        ]
      },
      {
        "title": "Connection",
        "description": "Connection Details",
        "id": "connection",
        "properties": [
          "connection"
        ]
      },
      {
        "title": "Metadata",
        "description": "Metadata",
        "id": "metadata",
        "properties": [
          "include-collections",
          "exclude-collections",
          "preflight-check"
        ]
      }
    ]
  }
}
